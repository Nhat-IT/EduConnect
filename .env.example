NODE_ENV=production
PORT=3000

# If omitted and DB vars are missing, app auto-runs in PREVIEW_MODE.
# Set explicitly to false when deploying full MySQL mode.
PREVIEW_MODE=true

DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=your-mysql-database
DB_CONNECTION_LIMIT=10

SESSION_NAME=educonnect.sid
SESSION_SECRET=put_a_long_random_secret_here
SESSION_MAX_AGE=604800000

# If app is behind reverse proxy/load balancer, set TRUST_PROXY=1
TRUST_PROXY=1

# true | false | auto (recommended for hosted env)
COOKIE_SECURE=auto
COOKIE_SAMESITE=lax
